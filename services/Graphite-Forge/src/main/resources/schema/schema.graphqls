type Query {
  getPolicy(id: ID!): Policy
  getPolicyById(id: ID!): Policy
  listPolicies: [Policy!]!
  searchPolicies(query: String): [Policy!]!
  evaluatePolicy(input: PolicyEvaluationInput!): PolicyEvaluationResult!

  getIdentity(sub: String!): Identity
  identity(id: ID!): Identity
  getIdentityById(id: ID!): Identity
  listIdentities(tenantId: String!): [Identity!]!
  getUserPermissions(identityId: ID!): [String!]!

  getTenant(id: ID!): Tenant
  tenant(id: ID!): Tenant
  getTenantById(id: ID!): Tenant
  listTenants: [Tenant!]!

  getAuditTrail(tenantId: String!): [AuditEvent!]!
  getAuditLogs(tenantId: String!): [AuditEvent!]!
  auditLogs(tenantId: String!): [AuditEvent!]!
  filterAuditLogs(filter: AuditLogFilterInput!): [AuditEvent!]!
  getAuditLogById(id: ID!): AuditEvent

  getPolicyStatistics(tenantId: String!): PolicyStatistics!
  policyStats(tenantId: String!): PolicyStatistics!
  getUserActivitySummary(tenantId: String!): [UserActivitySummary!]!
  userActivity(tenantId: String!): [UserActivitySummary!]!
  getResourceAccessPatterns(tenantId: String!): [ResourceAccessPattern!]!
  resourceAccess(tenantId: String!): [ResourceAccessPattern!]!

  listBuckets(jwtToken: String): [S3Bucket!]!
  getBucket(jwtToken: String, bucketName: String!): S3Bucket
  listObjects(
    jwtToken: String
    bucket: String!
    prefix: String
    query: String
    sortBy: String
    sortDirection: String
  ): [S3Object!]!
  getObject(jwtToken: String!, bucketName: String!, objectKey: String!): S3Object
  getBucketRoutingDecision(
    jwtToken: String!
    tenantId: String!
    bucketName: String!
    requiredCapability: String!
  ): ProviderRoutingDecision!
  getProviderCapabilityMatrix(jwtToken: String!): [ProviderCapabilityProfile!]!
  providersSupportingCapabilities(jwtToken: String!, requiredCapabilities: [String!]!): [String!]!
  getCapabilityAwareRoutingDecision(
    jwtToken: String!
    tenantId: String!
    bucketName: String!
    requiredCapabilities: [String!]!
    deniedProviders: [String!]
  ): ProviderRoutingDecision!
}

type Mutation {
  createBucket(jwtToken: String!, bucketName: String!, ownerTenant: String!): S3Bucket!
  deleteBucket(jwtToken: String!, bucketName: String!): Boolean!
  uploadObject(jwtToken: String, bucket: String!, key: String!, content: String!, contentType: String): UploadObjectResult!
  deleteObject(jwtToken: String, bucket: String!, key: String!): Boolean!
  downloadObject(jwtToken: String, bucket: String!, key: String!): DownloadObjectResult!

  createPolicy(input: PolicyInput!): Policy!
  addPolicy(input: PolicyInput!): Policy!
  updatePolicy(id: ID!, input: PolicyInput!): Policy!
  deletePolicy(id: ID!): Boolean!
  validatePolicy(input: PolicyInput!): ValidationResult!

  createIdentity(input: IdentityInput!): Identity!
  addUser(input: IdentityInput!): Identity!
  updateIdentity(id: ID!, input: IdentityInput!): Identity!
  updateUser(id: ID!, input: IdentityInput!): Identity!
  deleteIdentity(id: ID!): Boolean!
  removeUser(id: ID!): Boolean!

  createTenant(input: TenantInput!): Tenant!
  addTenant(input: TenantInput!): Tenant!
  updateTenant(id: ID!, input: TenantInput!): Tenant!
  deleteTenant(id: ID!): Boolean!
}

type Subscription {
  auditLogSubscription(tenantId: String!): AuditEvent!
  onAuditLog(tenantId: String!): AuditEvent!
}

type Policy {
  id: ID!
  tenantId: String!
  principal: String!
  resource: String!
  action: String!
  effect: String!
  version: Int!
  enabled: Boolean!
}

type Identity {
  id: ID!
  sub: String!
  tenantId: String!
  username: String!
  email: String
  permissions: [String!]!
}

type Tenant {
  id: ID!
  name: String!
  status: String!
}

type AuditEvent {
  id: ID!
  tenantId: String!
  actor: String!
  action: String!
  resource: String!
  timestamp: String!
  decision: String!
}

type PolicyEvaluationResult {
  allow: Boolean!
  reason: String!
}

type ValidationResult {
  valid: Boolean!
  errors: [String!]!
}

type PolicyStatistics {
  tenantId: String!
  totalPolicies: Int!
  evaluationCount: Int!
}

type UserActivitySummary {
  identityId: ID!
  operations: Int!
  lastSeen: String!
}

type ResourceAccessPattern {
  resource: String!
  accesses: Int!
}

type S3Bucket {
  name: String!
  creationDate: String
  ownerTenant: String!
  selectedProvider: String
  routingReason: String
}

type S3Object {
  key: String!
  bucketName: String!
  size: Int!
  lastModified: String
  contentType: String
  metadata: [MetadataEntry!]!
  selectedProvider: String
  routingReason: String
}

type UploadObjectResult {
  key: String!
  bucket: String!
  size: Int!
}

type DownloadObjectResult {
  url: String!
}

type MetadataEntry {
  key: String!
  value: String!
}

type ProviderRoutingDecision {
  tenantId: String!
  bucketName: String!
  requiredCapability: String!
  selectedProvider: String!
  reason: String!
}

type ProviderCapabilityProfile {
  provider: String!
  capabilities: [String!]!
}

input PolicyInput {
  tenantId: String!
  principal: String!
  resource: String!
  action: String!
  effect: String!
}

input IdentityInput {
  tenantId: String!
  username: String!
  email: String
}

input TenantInput {
  name: String!
  status: String!
}

input AuditLogFilterInput {
  tenantId: String!
  actor: String
  action: String
  resource: String
}

input PolicyEvaluationInput {
  tenantId: String!
  principal: String!
  resource: String!
  action: String!
}
