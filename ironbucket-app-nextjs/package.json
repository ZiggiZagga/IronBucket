{
  "name": "ironbucket-app",
  "version": "0.1.0",
  "main": "dist/index.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "jest --passWithNoTests",
    "test:e2e:ui": "playwright test --config playwright.config.ts tests/ui-live-upload-persistence.spec.ts",
    "test:e2e:ui:live": "playwright test --config playwright.config.ts tests/ui-live-upload-persistence.spec.ts",
    "test:e2e:ui:s3-methods": "playwright test --config playwright.config.ts tests/ui-s3-methods-e2e.spec.ts",
    "test:e2e:ui:all": "playwright test --config playwright.config.ts tests/ui-live-upload-persistence.spec.ts tests/ui-s3-methods-e2e.spec.ts"
  },
  "dependencies": {
    "@apollo/client": "^3.8.0",
    "express": "^4.19.2",
    "graphql": "^16.0.0",
    "next": "^15.5.4",
    "nuqs": "^2.8.9",
    "openid-client": "^6.8.1",
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.0",
    "@types/node": "^24.5.2",
    "@types/react": "^19.1.15",
    "@types/supertest": "^2.0.12",
    "autoprefixer": "^10.4.14",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "postcss": "^8.4.27",
    "supertest": "^6.3.3",
    "tailwindcss": "^4.1.17",
    "ts-jest": "^29.1.1",
    "typescript": "^5.9.2"
  },
  "jest": {
    "preset": "ts-jest",
    "transform": {
      "^.+\\.(ts|tsx)$": [
        "ts-jest",
        {
          "tsconfig": "tsconfig.test.json"
        }
      ]
    },
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1"
    },
    "testPathIgnorePatterns": [
      "<rootDir>/dist/",
      "<rootDir>/tests/"
    ]
  }
}
