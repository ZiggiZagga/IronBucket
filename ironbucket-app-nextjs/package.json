{
  "name": "ironbucket-app",
  "version": "0.1.0",
  "main": "dist/index.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "jest --passWithNoTests",
    "test:e2e:ui": "playwright test --config playwright.config.ts tests/object-browser-baseline.spec.ts tests/ui-live-upload-persistence.spec.ts tests/ui-s3-methods-e2e.spec.ts tests/ui-s3-methods-performance.spec.ts tests/ui-governance-methods-e2e.spec.ts",
    "test:e2e:ui:live": "playwright test --config playwright.config.ts tests/ui-live-upload-persistence.spec.ts",
    "test:e2e:ui:s3-methods": "playwright test --config playwright.config.ts tests/ui-s3-methods-e2e.spec.ts",
    "test:e2e:ui:performance": "playwright test --config playwright.config.ts tests/ui-s3-methods-performance.spec.ts",
    "test:e2e:ui:cinematic": "playwright test --config playwright.config.ts tests/ui-cinematic-showcase.spec.ts",
    "test:e2e:ui:mixed-observability-performance": "playwright test --config playwright.config.ts tests/ui-mixed-actor-observability-performance.spec.ts",
    "test:e2e:ui:governance": "playwright test --config playwright.config.ts tests/ui-governance-methods-e2e.spec.ts",
    "test:e2e:ui:tenant-foundation": "playwright test --config playwright.config.ts tests/ui-tenant-management-foundation.spec.ts",
    "test:e2e:ui:tenant-rbac": "playwright test --config playwright.config.ts tests/ui-tenant-membership-rbac.spec.ts",
    "test:e2e:ui:policy-engine": "playwright test --config playwright.config.ts tests/ui-policy-engine-management.spec.ts tests/ui-policy-engine-diff-gitops.spec.ts",
    "test:e2e:ui:all": "playwright test --config playwright.config.ts tests/object-browser-baseline.spec.ts tests/ui-live-upload-persistence.spec.ts tests/ui-s3-methods-e2e.spec.ts tests/ui-s3-methods-performance.spec.ts tests/ui-governance-methods-e2e.spec.ts tests/ui-tenant-management-foundation.spec.ts tests/ui-tenant-membership-rbac.spec.ts tests/ui-policy-engine-management.spec.ts tests/ui-policy-engine-diff-gitops.spec.ts"
  },
  "dependencies": {
    "@apollo/client": "^3.8.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-toast": "^1.2.15",
    "@tanstack/react-query": "^5.95.0",
    "@vercel/otel": "^1.11.0",
    "better-auth": "^1.5.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "express": "^4.19.2",
    "graphql": "^16.0.0",
    "js-yaml": "^4.1.0",
    "lucide-react": "^0.577.0",
    "next": "^15.5.4",
    "next-themes": "^0.4.6",
    "nuqs": "^2.8.9",
    "openid-client": "^6.8.1",
    "prom-client": "^15.1.3",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.0",
    "@types/node": "^24.5.2",
    "@types/js-yaml": "^4.0.9",
    "@types/react": "^19.1.15",
    "@types/supertest": "^2.0.12",
    "autoprefixer": "^10.4.14",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-util": "^29.7.0",
    "postcss": "^8.4.27",
    "supertest": "^6.3.3",
    "tailwindcss": "^4.1.17",
    "ts-jest": "^29.1.1",
    "typescript": "^5.9.2"
  },
  "jest": {
    "preset": "ts-jest",
    "transform": {
      "^.+\\.(ts|tsx)$": [
        "ts-jest",
        {
          "tsconfig": "tsconfig.test.json"
        }
      ]
    },
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1"
    },
    "testPathIgnorePatterns": [
      "<rootDir>/dist/",
      "<rootDir>/tests/"
    ]
  }
}
