{
  "title": "IronBucket Performance",
  "uid": "ironbucket-performance",
  "timezone": "browser",
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Gateway Request Rate (rps)",
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(http_server_requests_seconds_count{job=\"steel-hammer-sentinel-gear\"}[5m]))",
          "legendFormat": "sentinel-gear"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Gateway p95 Latency (seconds)",
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_server_requests_seconds_bucket{job=\"steel-hammer-sentinel-gear\"}[5m])))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Postgres Throughput (commits/sec)",
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(pg_stat_database_xact_commit{job=\"steel-hammer-postgres-exporter\",datname!~\"template0|template1\"}[5m]))",
          "legendFormat": "postgres commits"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Postgres Active Connections",
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(pg_stat_database_numbackends{job=\"steel-hammer-postgres-exporter\",datname!~\"template0|template1\"})",
          "legendFormat": "active backends"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "MinIO S3 Requests (rps)",
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(minio_s3_requests_total{job=\"steel-hammer-minio\"}[5m]))",
          "legendFormat": "minio requests"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "MinIO S3 Errors (rps)",
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(minio_s3_requests_errors_total{job=\"steel-hammer-minio\"}[5m]))",
          "legendFormat": "minio errors"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "version": 1
}
